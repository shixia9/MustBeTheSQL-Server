# =============================================================
# 本地开发环境配置模板
# =============================================================
# 使用方法：
#   1. 复制此文件为 application-local.yml
#      cp application-local.yml.example application-local.yml
#   2. 根据你的实际环境，修改 NACOS_ADDR 等环境变量默认值
#   3. 确保项目根目录的 .env 文件已正确配置
#   4. 启动时使用 Spring Profile: local
#      mvn spring-boot:run -Dspring-boot.run.profiles=local
#
# ⚠️ application-local.yml 已在 .gitignore 中排除，不会提交到 Git
# =============================================================

spring:
  application:
    name: sql-logic-service
  config:
    import: optional:nacos:sql-logic-service.yml?group=DEFAULT_GROUP&refreshEnabled=true
  cloud:
    nacos:
      # 服务注册发现
      discovery:
        server-addr: ${NACOS_ADDR:localhost:8848}
        namespace: ${NACOS_NAMESPACE:}
        enabled: true
      # 配置中心
      config:
        server-addr: ${NACOS_ADDR:localhost:8848}
        namespace: ${NACOS_NAMESPACE:}
        # 共享配置：Sa-Token 等
        shared-configs:
          - data-id: shared-config.yml
            group: DEFAULT_GROUP
            refresh: true
        enabled: true

# 本地开发关闭内部认证过滤器——因为直连 Service 没有 Gateway 注入 X-User-Id 头
# 生产环境走 Gateway 时必须设为 true
engine:
  auth:
    internal-filter-enabled: false
  # ⚠️ 此密钥仅用于本地开发，生产环境必须通过 Nacos 配置中心或环境变量 AES_KEY 注入
  crypto:
    aes-key: YOUR_AES_KEY_BASE64